# forge-mcp — example environment variables.
#
# Copy this file to `.env` (git-ignored) OR set these in the shell / MCP
# client config that spawns forge-mcp. All four are read at server start
# (see src/forge_mcp/server.py::main + tools/*).
#
# Drain CW-MCP-cc-integration — this file is the source of truth for what
# a Claude Code (or other MCP client) install needs to hand forge-mcp.

# Required — the Bearer token forge-mcp forwards to forge-transpile on every
# authenticated call. Get yours from your Obsidian plugin's data.json:
#
#   jq -r '.transpileServiceToken' \
#     ~/forge-vaults/bluh/.obsidian/plugins/forge-client-obsidian/data.json
#
# Rotation: change FORGE_TRANSPILE_SECRET on the forge-transpile service side,
# then update this value. Old tokens fail on the next call with an isError
# whose text names FORGE_MCP_BEARER (CW-MCP-1-B translation path).
FORGE_MCP_BEARER=paste-your-token-here

# Base URL of the forge-transpile service (backs the read/author tools —
# /catalog, /compile, /run, /resolve-slot). Default assumes local dev on
# port 8000; for hosted use the production URL.
FORGE_TRANSPILE_URL=http://localhost:8000
# FORGE_TRANSPILE_URL=https://forge.thecodingarena.com

# Local vault directory. Used by `forge_read_notes_in_vault` (walks it) and
# `forge_commit_recipe` (writes into it). MUST exist + be writable.
FORGE_VAULT_PATH=~/forge-vaults/bluh

# Transport picker for `main()`. `stdio` is what Claude Code spawns as a
# subprocess; `streamable-http` is what Docker + systemd deployments serve
# on port 8765. `sse` is legacy MCP.
#   - Claude Code install: FORGE_MCP_TRANSPORT=stdio
#   - Everything else:     FORGE_MCP_TRANSPORT=streamable-http  (default)
FORGE_MCP_TRANSPORT=streamable-http

# Only used when FORGE_MCP_TRANSPORT=streamable-http. Default 0.0.0.0:8765.
FORGE_MCP_HOST=0.0.0.0
FORGE_MCP_PORT=8765
